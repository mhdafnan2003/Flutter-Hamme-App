NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
CLIENT_ORIGIN=http://localhost:5173,https://your-frontend-project.vercel.app
PUBLIC_BASE_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=hamme/profile
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ENABLE_SOCKETS=false
PENDING_TTL_SECONDS=60

# ---- In-app purchases (Google Play billing) ----
# Product ids (comma separated) that grant Pro. Must match Play Console.
PRO_PRODUCT_IDS=hamme_pro_weekly
# Your Android application id (package name), e.g. com.hamme.app
ANDROID_PACKAGE_NAME=
# Google Play service account credentials for purchase verification.
# Provide ONE of the following:
#   - GOOGLE_PLAY_SERVICE_ACCOUNT_JSON: the full service-account JSON (single line)
#   - GOOGLE_PLAY_SERVICE_ACCOUNT_FILE: absolute path to the JSON key file
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=
# DEV ONLY: set to true to grant Pro without server-side verification.
# Never enable in production.
ALLOW_UNVERIFIED_IAP=false

# ---- Admin panel ----
# Shared secret for the admin plan-manager at /api/v1/admin.
# Leave empty to disable the admin API entirely.
ADMIN_API_KEY=
